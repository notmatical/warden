{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:event:default",
    "core:window:default",
    "opener:default",
    "dialog:default",
    "os:default",
    "notification:default",
    "clipboard-manager:allow-write-text",
    "clipboard-manager:allow-read-text",
    "process:default",
    "window-state:default"
  ]
}
