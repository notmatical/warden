{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Warden",
  "version": "0.3.0",
  "identifier": "com.warden.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "bun run dev:web",
    "beforeBuildCommand": "bun run build:web"
  },
  "app": {
    "macOSPrivateApi": true,
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Warden",
        "width": 1280,
        "height": 900,
        "minWidth": 880,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "maximized": false,
        "center": true,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "alwaysOnTop": false,
        "transparent": true,
        "shadow": true,
        "dragDropEnabled": true
      },
      {
        "label": "notifications",
        "title": "Warden Notifications",
        "url": "notification.html",
        "width": 372,
        "height": 96,
        "visible": false,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "focus": false,
        "focusable": false,
        "acceptFirstMouse": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "publisher": "Nick Reatherford",
    "category": "DeveloperTool",
    "shortDescription": "A browser for your AI agents.",
    "longDescription": "Open every AI coding agent in a tab. Warden runs them in parallel, each isolated in its own git worktree and orchestrates handoffs between them through repeatable workflows.",
    "copyright": "Copyright © 2026 Nick Reatherford",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/notmatical/warden/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IERBNjAzOTZDQkYzQjI1MTcKUldRWEpUdS9iRGxnMm14OTdNSDNLTDJpd1ZpK3UrZjY2TzRSOGNrczN4SWdjRzJFUEhNYzdxRk8K"
    }
  }
}
