{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Warden",
  "version": "0.2.0",
  "identifier": "com.warden.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "bun run dev:web",
    "beforeBuildCommand": "bun run build:web"
  },
  "app": {
    "windows": [
      {
        "title": "Warden",
        "width": 1280,
        "height": 900,
        "minWidth": 880,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "maximized": false,
        "center": true,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "alwaysOnTop": false,
        "transparent": true,
        "shadow": true,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/notmatical/warden/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IERBNjAzOTZDQkYzQjI1MTcKUldRWEpUdS9iRGxnMm14OTdNSDNLTDJpd1ZpK3UrZjY2TzRSOGNrczN4SWdjRzJFUEhNYzdxRk8K"
    }
  }
}
